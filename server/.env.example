# Banco de dados PostgreSQL na VPS
DB_HOST=seu_ip_ou_dominio_vps
DB_PORT=5432
DB_NAME=setebus
DB_USER=postgres
DB_PASSWORD=sua_senha_aqui
DB_SSL=false

# Autenticação
JWT_SECRET=gere_uma_string_aleatoria_longa_aqui_ex_64chars
ADMIN_PASSWORD=senha_do_painel_admin

# Servidor
PORT=3001
NODE_ENV=production

# URL do frontend (para CORS em desenvolvimento)
FRONTEND_URL=http://localhost:5173
